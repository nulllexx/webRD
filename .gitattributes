# Default: let git detect text vs. binary and normalize text to LF
* text=auto eol=lf

# Explicitly mark binary files so git never touches their contents
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.avif  binary
*.bmp   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.7z    binary
*.mp3   binary
*.mp4   binary
*.webm  binary
*.mov   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
